# OpenLLM Metrics — environment variable reference for docker compose up.
#
# Usage:
#   cp .env.example .env
#   # Fill in real values.
#   docker compose up -d
#
# Never commit .env — it is excluded by .gitignore.
# Compose deployment secrets (e.g. AUTH_SECRET below) belong HERE: the
# containerized admin console only receives what docker-compose.yml forwards
# from this file. apps/web/admin-console/.env.local is read only by the
# host-mode `pnpm dev` console, never by the container.

# ── Optional: pull-mode exporter add-on (not in the default stack) ───────────
#
# The default product uses RUNTIME mode (the Go gateway + SDKs) and needs no
# exporter. To enable the optional pull-mode billing-reconciliation path,
# bring your own image: set LLM_USAGE_EXPORTER_IMAGE to an llm-usage-exporter
# image you can pull (the pinned upstream default in docker-compose.yml may
# not be publicly pullable), then:
#   docker compose --profile exporter up -d
# The non-OpenAI provider keys below are only consumed by this optional path.
# LLM_USAGE_EXPORTER_IMAGE=ghcr.io/your-org/llm-usage-exporter:v0.5.0

# ── Provider credentials (llm-usage-exporter + openai-poller) ────────────────
#
# Keys are forwarded from host env to the relevant containers only.
# They are never logged, traced, or echoed — Compose passes them as opaque
# env vars. Use a scoped secret store in production.

# OpenAI — Usage/Admin API key (required for openai-poller and llm-usage-exporter).
OPENAI_ADMIN_API_KEY=sk-admin-REPLACE_ME
# llm-usage-exporter uses OPENAI_ADMIN_KEY (different var name from the poller).
OPENAI_ADMIN_KEY=sk-admin-REPLACE_ME

# Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Google AI / Vertex AI
GOOGLE_AI_API_KEY=AIza-REPLACE_ME

# Azure OpenAI (both required if using Azure routes via the gateway)
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_ENDPOINT=https://REPLACE_ME.openai.azure.com

# AWS Bedrock
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=us-east-1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
#
# The compose file inlines the postgres:// DSN for each service so they
# always connect to the right host. Change POSTGRES_PASSWORD here to rotate
# the dev credential across the whole stack in one edit.
# NOTE: Postgres reads POSTGRES_PASSWORD only when the postgres-data volume is
# first initialized. After the first boot, an edit here breaks every DSN:
# either wipe state (docker compose down -v) or run ALTER ROLE inside the
# container to change the live password first.

POSTGRES_PASSWORD=devpassword

# ── Redpanda / streaming bus ──────────────────────────────────────────────────
#
# Broker addresses are not configured via env: each service reads bus.brokers
# from its YAML in platform/deployment/compose/configs/*.yaml (in-network
# address redpanda:9092). The host-exposed Kafka bootstrap for external
# tooling is localhost:19092; the schema registry is http://localhost:18081.

# ── Gateway upstream URL overrides ───────────────────────────────────────────
#
# Leave empty to use the built-in defaults (api.openai.com, api.anthropic.com,
# generativelanguage.googleapis.com, bedrock-runtime.us-east-1.amazonaws.com).
# Set to override per-provider endpoint (e.g., Azure region, private VPC).

OLM_UPSTREAM_OPENAI_URL=
OLM_UPSTREAM_ANTHROPIC_URL=
OLM_UPSTREAM_GEMINI_URL=
OLM_UPSTREAM_BEDROCK_URL=
OLM_UPSTREAM_AZURE_OPENAI_URL=

# ── Service ports (host-side) ─────────────────────────────────────────────────
#
# Documented here for reference; the docker-compose.yml hardcodes these values.
# Change them in docker-compose.yml if you need to remap.
#
# Admin Console      : 3030
# Grafana            : 3000
# Prometheus         : 9090
# llm-usage-exporter : 9095  (--profile exporter)
# metrics-endpoint   : 9092
# openai-poller      : 8088
# label-translator   : 8081  (--profile exporter)
# focus-ingester     : 8082  (--profile exporter)
# cost-mapper        : 8083
# reconciler         : 8084
# gateway (proxy)    : 8085
# gateway (metrics)  : 8086
# quota-risk         : 8087
# demo-generator     : 8089  (--profile demo)
# policy-service     : 8090
# audit-service      : 8091
# notifier           : 8092
# decision-service   : 8093
# Redpanda Console   : 8095
# analytics-service  : 8096
# OTLP gRPC          : 4317
# OTLP HTTP          : 4318
# OTel Prom exporter : 8889
# OTel health        : 13133
# PostgreSQL         : 5433
# Redpanda Kafka     : 19092
# Redpanda Schema    : 18081
# Redpanda Pandaproxy: 18082
# Redpanda Admin API : 9644

# ── Admin console identity (dev stub) ────────────────────────────────────────
#
# Forwarded to backends as X-OLM-User / X-Actor. Replace with real OIDC
# claims when wiring NextAuth (F005). Matches the seeded Acme tenant-admin
# actor from platform/db/seeds/001_demo_data.sql.

OLM_DEV_USER=admin@acme.dev

# Auth.js (next-auth) JWT signing secret for the containerized console.
# docker-compose.yml falls back to an insecure local-dev default
# (olm-local-dev-insecure-secret-change-me) — set a real random value for
# anything beyond local dev.
# AUTH_SECRET=change-me-to-a-long-random-string

# ── Demo tenant ───────────────────────────────────────────────────────────────
#
# All demo data lands under the seeded "Acme Corp" tenant
# (00000000-0000-0000-0002-000000000001 — see platform/db/seeds/README.md):
# the console's dev-login session opens on it (OLM_DEFAULT_TENANT) and the
# --profile demo generator attributes its synthetic traffic to it
# (OLM_DEMO_TENANT). If you change one, change both, or the analytics screens
# will look empty. OLM_DEMO_RPS tunes the generator's events per second.
# OLM_DEFAULT_TENANT=00000000-0000-0000-0002-000000000001
# OLM_DEMO_TENANT=00000000-0000-0000-0002-000000000001
# OLM_DEMO_RPS=4
