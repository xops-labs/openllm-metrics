# OpenLLM Metrics — admin console env example (canonical, fully annotated).
# Host mode: copy to .env.local and adjust. EVERY var here is optional: with
# none set, the console boots with a local dev-login and the analytics screens
# render an explanatory empty-state.
# Container mode: the admin-console container only receives what
# docker-compose.yml forwards — this file is not read there.

# ---------------------------------------------------------------------------
# Backend service base URLs
# ---------------------------------------------------------------------------
# Defaults assume the local docker-compose host ports.
OLM_POLICY_SERVICE_URL=http://localhost:8090
OLM_AUDIT_SERVICE_URL=http://localhost:8091
OLM_NOTIFICATION_SERVICE_URL=http://localhost:8092
OLM_DECISION_SERVICE_URL=http://localhost:8093

# ---------------------------------------------------------------------------
# Native analytics data source (F038)
# ---------------------------------------------------------------------------
# Base URL of a Prometheus-compatible query API (Prometheus, VictoriaMetrics,
# or Mimir) that scrapes the metrics-endpoint service (F010). The analytics
# screens issue PromQL via {URL}/api/v1/query and /api/v1/query_range.
# Leave unset to disable the native analytics screens (they show a hint).
OLM_METRICS_QUERY_URL=http://localhost:9090

# Saved-views persistence (F038): base URL of analytics-service, which stores
# user-defined dashboard views. The compose stack publishes it on host port
# 8096 (host 8095 is Redpanda Console). Optional — when unreachable, the
# dashboards screen serves the built-in views and create/delete are soft no-ops.
OLM_ANALYTICS_SERVICE_URL=http://localhost:8096

# ---------------------------------------------------------------------------
# Control plane + exports
# ---------------------------------------------------------------------------
# Tenant list endpoint backing the tenant switcher (GET {URL}/v1/tenants) and
# the optional exports config persistence (PUT/GET {URL}/v1/exports; F039).
# Unset = built-in dev seed / process-local dev store. No in-repo service
# serves these yet (F005 / F039) — point at your own control-plane
# implementation.
# OLM_CONTROL_PLANE_URL=
# OLM_EXPORTS_CONFIG_URL=

# ---------------------------------------------------------------------------
# Grafana embeds
# ---------------------------------------------------------------------------
# Browser-reachable Grafana base URL for the /slo iframe embeds — the iframes
# load in YOUR browser, so a compose-internal hostname will not work. The
# compose stack serves Grafana on http://localhost:3000. Leave empty to
# disable the embeds.
OLM_GRAFANA_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Identity / OIDC (F005)
# ---------------------------------------------------------------------------
# When OIDC_ISSUER + OIDC_CLIENT_ID + OIDC_CLIENT_SECRET are all set, the
# console uses a real generic-OIDC provider (Auth.js). When any is missing it
# falls back to a local dev-login (/dev-login) so the app boots with zero
# config: any email works; admin@acme.dev is the seeded admin used by default.
# AUTH_SECRET=generate-with: openssl rand -base64 32
# OIDC_ISSUER=https://idp.example.com/realms/openllm
# OIDC_CLIENT_ID=openllm-admin-console
# OIDC_CLIENT_SECRET=change-me
# JWT claim that carries the tenant id (default: tenant).
# OIDC_TENANT_CLAIM=tenant

# Default tenant when no claim/cookie is present. This UUID is Acme Corp, the
# demo tenant seeded by the compose stack (platform/db/seeds/001_demo_data.sql),
# so a host-mode console pointed at the compose services sees the demo data.
OLM_DEFAULT_TENANT=00000000-0000-0000-0002-000000000001

# Actor id used by the local dev-login when no email is entered. Any email
# works; admin@acme.dev is the admin user in the seeded demo data.
OLM_DEV_USER=admin@acme.dev
