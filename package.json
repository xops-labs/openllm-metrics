{
  "name": "openllm-metrics",
  "version": "0.0.0",
  "private": true,
  "description": "Vendor-neutral telemetry and observability for multi-provider LLM APIs",
  "license": "Apache-2.0",
  "author": "Yasvanth Udayakumar <yasvanth@live.in>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasvanth511/openllm-metrics-oss.git"
  },
  "bugs": {
    "url": "https://github.com/yasvanth511/openllm-metrics-oss/issues"
  },
  "homepage": "https://github.com/yasvanth511/openllm-metrics-oss#readme",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml,yml}\" --ignore-path .gitignore --ignore-path .prettierignore"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.15.0"
}
