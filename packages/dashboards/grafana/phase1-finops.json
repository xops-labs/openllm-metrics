        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "(sum(increase(llm_cost_usd_total{tenant=~\"$tenant\",env=~\"$env\",team=~\"$team\",app=~\"$app\",provider=~\"$provider\",model=~\"$model\"}[7d])) / 7) * 30",
