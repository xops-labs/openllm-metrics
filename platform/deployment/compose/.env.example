#
# OpenLLM Metrics — quickstart .env template.
#
# Compose loads `.env` from the directory of the compose file (this one), NOT
# from your current working directory. Usage:
#
#   cd platform/deployment/compose
#   cp .env.example .env
#   # edit values
#   docker compose -f quickstart.yml up -d
#
# or, staying at the repo root:
#
#   cp platform/deployment/compose/.env.example platform/deployment/compose/.env
#   # edit values
#   docker compose -f platform/deployment/compose/quickstart.yml up -d
#
# Never commit `.env` (the repo root .gitignore already excludes it).

# OpenAI Admin API key with Usage scope. The stack parses and starts without
# it (a non-empty placeholder is the default), but the F009 poller only pulls
# real OpenAI billing data with a valid key.
OPENAI_ADMIN_API_KEY=sk-admin-replace-me

# Optional pull-mode leg (--profile exporter): bring your own exporter image.
# The pinned upstream default in quickstart.yml may not be publicly pullable.
# LLM_USAGE_EXPORTER_IMAGE=ghcr.io/your-org/llm-usage-exporter:v0.5.0
