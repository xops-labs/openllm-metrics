{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Availability SLO view: uptime %, error budget remaining, error spikes. Powered by the SLO recording rules at platform/slo/prometheus/recording-rules.yaml and the gateway request counter llm_gateway_requests_total (F018).",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "OpenLLM Metrics SLO framework docs",
      "tooltip": "How to author SLOs and read these dashboards",
      "type": "link",
      "url": "https://github.com/yasvanth511/openllm-metrics-oss/blob/main/docs/product/slo-framework.md"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Availability overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Observed gateway success ratio over the dashboard time range. The SLO target is typically 0.995 (three-and-a-half nines).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 4,
          "mappings": [],
          "max": 1,
          "min": 0.99,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "1 - (sum(rate(llm_gateway_requests_total{status_code!~\"2..\",tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}[$__range])) / clamp_min(sum(rate(llm_gateway_requests_total{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}[$__range])), 1))",
          "instant": true,
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "title": "Uptime (range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Fraction of the 30-day availability error budget still available. 1.0 = full budget, 0.0 = budget exhausted.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.75 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "avg(slo:availability:budget_remaining:30d{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"})",
          "instant": true,
          "legendFormat": "Budget remaining",
          "refId": "A"
        }
      ],
      "title": "30d error budget remaining",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total non-2xx responses over the dashboard time range. A quick sense of absolute error volume.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 0,
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(increase(llm_gateway_requests_total{status_code!~\"2..\",tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}[$__range]))",
          "instant": true,
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "title": "Total errors (range)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "panels": [],
      "title": "Error rate over time",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Error ratio at 1h, 6h, 1d, and 3d windows. Each line plots one of the SLI recording-rule series; spikes are what feed the burn-rate alerts.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "error ratio",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(sli:availability:error_ratio:1h{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"})",
          "legendFormat": "1h",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(sli:availability:error_ratio:6h{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"})",
          "legendFormat": "6h",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(sli:availability:error_ratio:1d{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"})",
          "legendFormat": "1d",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(sli:availability:error_ratio:3d{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"})",
          "legendFormat": "3d",
          "refId": "D"
        }
      ],
      "title": "Error ratio (multi-window)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["openllm-metrics", "slo", "availability"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "openllm-prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(llm_gateway_requests_total, tenant)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": true,
        "name": "tenant",
        "query": { "query": "label_values(llm_gateway_requests_total, tenant)", "refId": "tenant" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\"}, team)",
        "hide": 0,
        "includeAll": true,
        "label": "Team",
        "multi": true,
        "name": "team",
        "query": {
          "query": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\"}, team)",
          "refId": "team"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\",team=~\"$team\"}, app)",
        "hide": 0,
        "includeAll": true,
        "label": "App",
        "multi": true,
        "name": "app",
        "query": {
          "query": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\",team=~\"$team\"}, app)",
          "refId": "app"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OpenLLM Metrics - SLO Availability",
  "uid": "openllm-slo-availability",
  "version": 1,
  "weekStart": ""
}
