        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\"}, team)",
        "hide": 0,
        "includeAll": true,
        "label": "Team",
        "multi": true,
        "name": "team",
        "query": {
          "query": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\"}, team)",
          "refId": "team"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\",team=~\"$team\"}, app)",
        "hide": 0,
        "includeAll": true,
        "label": "App",
        "multi": true,
        "name": "app",
        "query": {
          "query": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\",team=~\"$team\"}, app)",
          "refId": "app"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OpenLLM Metrics - SLO Cost",
  "uid": "openllm-slo-cost",
  "version": 1,
  "weekStart": ""
