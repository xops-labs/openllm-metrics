{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Latency SLO view: error budget remaining, burn rate over time, and p50/p95/p99 latency. Powered by the SLO recording rules at platform/slo/prometheus/recording-rules.yaml and the gateway latency histogram llm_gateway_latency_seconds (F018).",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "OpenLLM Metrics SLO framework docs",
      "tooltip": "How to author SLOs and read these dashboards",
      "type": "link",
      "url": "https://github.com/yasvanth511/openllm-metrics-oss/blob/main/docs/product/slo-framework.md"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Error budget overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Fraction of the 30-day p99 latency error budget still available. 1.0 = full budget, 0.0 = budget exhausted.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.75 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "avg(slo:latency_p99:budget_remaining:30d{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"})",
          "instant": true,
          "legendFormat": "Budget remaining",
          "refId": "A"
        }
      ],
      "title": "30d p99 error budget remaining",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Burn rate at 1h, 6h, 1d, and 3d windows expressed as multiples of the steady-state burn (1.0 = on-budget). Spikes above the dashed alert thresholds are what fire the multi-window alerts in platform/slo/prometheus/alerts.yaml.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "burn rate (x normal)",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(sli:latency_p99:error_ratio:1h{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}) / 0.01",
          "legendFormat": "1h",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(sli:latency_p99:error_ratio:6h{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}) / 0.01",
          "legendFormat": "6h",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(sli:latency_p99:error_ratio:1d{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}) / 0.01",
          "legendFormat": "1d",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(sli:latency_p99:error_ratio:3d{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}) / 0.01",
          "legendFormat": "3d",
          "refId": "D"
        }
      ],
      "title": "Burn rate (multi-window)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "panels": [],
      "title": "Latency percentiles",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "p50, p95, and p99 latency derived from the gateway latency histogram. p99 is what the SLO objective tracks.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "latency (s)",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO bound (5s)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(llm_gateway_latency_seconds_bucket{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(llm_gateway_latency_seconds_bucket{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(llm_gateway_latency_seconds_bucket{tenant=~\"$tenant\",team=~\"$team\",app=~\"$app\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "vector(5)",
          "legendFormat": "SLO bound (5s)",
          "refId": "D"
        }
      ],
      "title": "p50 / p95 / p99 latency",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["openllm-metrics", "slo", "latency"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "openllm-prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(llm_gateway_requests_total, tenant)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": true,
        "name": "tenant",
        "query": { "query": "label_values(llm_gateway_requests_total, tenant)", "refId": "tenant" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\"}, team)",
        "hide": 0,
        "includeAll": true,
        "label": "Team",
        "multi": true,
        "name": "team",
        "query": {
          "query": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\"}, team)",
          "refId": "team"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\",team=~\"$team\"}, app)",
        "hide": 0,
        "includeAll": true,
        "label": "App",
        "multi": true,
        "name": "app",
        "query": {
          "query": "label_values(llm_gateway_requests_total{tenant=~\"$tenant\",team=~\"$team\"}, app)",
          "refId": "app"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OpenLLM Metrics - SLO Latency",
  "uid": "openllm-slo-latency",
  "version": 1,
  "weekStart": ""
}
